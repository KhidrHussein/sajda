<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#232B2F">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <TextView
            android:id="@+id/prayerNameTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Prayer is happening now."
            android:textColor="#F7F5F2"
            android:textSize="20sp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center" />

        <TextView
            android:id="@+id/timerTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10:00"
            android:textColor="#F7F5F2"
            android:textSize="48sp"
            android:fontFamily="sans-serif-light"
            android:layout_marginTop="24dp"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Remaining in window"
            android:textColor="#A0A6A9"
            android:textSize="14sp"
            android:layout_marginTop="8dp"
            android:gravity="center" />

        <TextView
            android:id="@+id/quoteTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quote"
            android:textColor="#F7F5F2"
            android:textSize="18sp"
            android:fontFamily="serif"
            android:textStyle="italic"
            android:layout_marginTop="48dp"
            android:paddingHorizontal="16dp"
            android:gravity="center" />

        <TextView
            android:id="@+id/quoteSourceTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Source"
            android:textColor="#A0A6A9"
            android:textSize="12sp"
            android:layout_marginTop="8dp"
            android:gravity="center" />

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_sajda_logo"
            android:layout_marginTop="48dp"
            android:alpha="0.2"
            android:tint="#F7F5F2" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/nextPrayerTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#F7F5F2"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="24dp"
            android:gravity="center" />

        <TextView
            android:id="@+id/skipButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Press and hold to exit"
            android:textColor="#A0A6A9"
            android:textSize="14sp"
            android:paddingHorizontal="24dp"
            android:paddingVertical="12dp"
            android:layout_marginBottom="48dp"
            android:gravity="center" />

    </LinearLayout>

</FrameLayout>
